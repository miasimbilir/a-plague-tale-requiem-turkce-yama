TT 11097 "Dur... Dur..." VO__BEATRICE__CH05__RTC__220_THE_ROPE__145__M__1
TT 11098 "Tanrim! Yasiyorsun!" VO__BEATRICE__CH12__RTC__610_A_BANQUET__030__M__1
