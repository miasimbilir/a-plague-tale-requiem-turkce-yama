TT 14926 "onom" VO__LUCAS__CH15__RTC__850_FIRE_ONOM__060__M__1
TT 14927 "Kos!" VO__LUCAS__CH16__CHATTER__4TH_COVER_FALL__020__M__1
TT 14928 "Ah... Kendimi yasli hissettirdi bu..." VO__LUCAS__CH16__CHATTER__CARNATION__020__M__1
