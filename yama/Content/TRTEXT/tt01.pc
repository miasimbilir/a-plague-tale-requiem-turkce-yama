TT 11387 "onom" VO__COUNT__CH15__RTC__825_UNFINISHED_DUEL_ONOM__050__M__1
TT 11388 "Kes sesini! Ben hallederim onu." VO__COUNT__CH15__RTC__830_NEBULA__250__M__1
TT 11389 "Hiçbir yere gitmiyorsun!" VO__COUNT__CH15__RTC__830_NEBULA__280__M__1
TT 11390 "Hayir! Öldürün su kizi!" VO__COUNT__CH15__RTC__830_NEBULA__300__M__1
