TT 20157 "Hey! Bu güzel bir çiçek!" VO__SOPHIA__CH10__RTC__480_ENTER_FORT__106__M__1
TT 20158 "Elbette!" VO__SOPHIA__CH10__RTC__480_ENTER_FORT__120__M__1
