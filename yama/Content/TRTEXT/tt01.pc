TT 18911 "Evet! Basardim!" VO__SOLDIER_S1__GENERIC__PATROL__FLEE_RATS_ESCAPE__001__M__2
TT 18912 "Bu... Basardim..." VO__SOLDIER_S1__GENERIC__PATROL__FLEE_RATS_ESCAPE__001__M__3
TT 18913 "Saldiriya ugradim! Bulun su serserileri!" VO__SOLDIER_S1__GENERIC__PATROL__HIT_SEARCH__001__M__1
