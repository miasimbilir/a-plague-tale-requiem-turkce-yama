TT 6572 "Aynen!" VO__AMICIA__CH11__CHATTER__PULLING_LEFT__050__M__1
TT 6573 "Sikismis... Gel... buraya!" VO__AMICIA__CH11__CHATTER__PULLING_TANK__010__M__1
TT 6574 "Evet... Bu yeter..." VO__AMICIA__CH11__CHATTER__PULLING_TANK__020__M__1
TT 6575 "Dogru. Halkina barinak sunmak Kont'un görevidir." VO__AMICIA__CH11__CHATTER__PUSHING_CART__020__M__1
TT 6576 "Görüyorum!" VO__AMICIA__CH11__CHATTER__PUSHING_TANK__020__M__1
TT 6577 "EMPTY" VO__AMICIA__CH11__CHATTER__RATS_BURSTING__010__M__1
TT 6578 "Onlari bos ver, Hugo! Nefes al! Kosmaya devam et!" VO__AMICIA__CH11__CHATTER__RATS_BURSTING__030__M__1
TT 6579 "Ne?!" VO__AMICIA__CH11__CHATTER__RATS_SWARM__020__M__1
TT 6580 "Hadi! Hadi!" VO__AMICIA__CH11__CHATTER__RATS_SWARM__040__M__1
