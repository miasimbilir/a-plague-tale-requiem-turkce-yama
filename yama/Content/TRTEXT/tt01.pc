TT 20102 "Git!" VO__SOPHIA__CH10__CHATTER__RUN_TOWER__050__M__1
TT 20103 "Vay... Su manzaraya bak!" VO__SOPHIA__CH10__CHATTER__SEA__010__M__1
TT 20104 "Henüz degil, ama geri gelecek..." VO__SOPHIA__CH10__CHATTER__SEA__030__M__1
TT 20105 "Hayir, ablana olan borcumu ödeyene kadar olmaz." VO__SOPHIA__CH10__CHATTER__SEA__050__M__1
TT 20106 "Sana söylemedi mi?! Hayatimi kurtardi!" VO__SOPHIA__CH10__CHATTER__SEA__070__M__1
TT 20107 "Sey, ben de!" VO__SOPHIA__CH10__CHATTER__SEA__100__M__1
TT 20108 "Bunu özleyecegimi söyleyemem." VO__SOPHIA__CH10__CHATTER__SECOND_AREA_KILL_1ST__010__M__1
TT 20109 "Bu beladan çikmamiz gerçekten lazim..." VO__SOPHIA__CH10__CHATTER__SECOND_AREA_KILL_2ND__020__M__1
TT 20110 "Amicia..." VO__SOPHIA__CH10__CHATTER__SECOND_AREA_KILL_4TH__010__M__1
TT 20111 "Kendini kaptirma..." VO__SOPHIA__CH10__CHATTER__SECOND_AREA_KILL_4TH__030__M__1
TT 20112 "Bu iki etti..." VO__SOPHIA__CH10__CHATTER__SECOND_KILL__010__M__1
TT 20113 "Pekâlâ... Yapman gerekeni yap..." VO__SOPHIA__CH10__CHATTER__SECOND_KILL__030__M__1
TT 20114 "Iste kalemiz!" VO__SOPHIA__CH10__CHATTER__SEE_FORT__020__M__1
TT 20115 "Sanirim... evet!" VO__SOPHIA__CH10__CHATTER__SEE_FORT__060__M__1
TT 20116 "Evet, sey... hadi sadece yürüyelim." VO__SOPHIA__CH10__CHATTER__SERIOUS_TALK__100__M__1
TT 20117 "Yaptiklari bu..." VO__SOPHIA__CH10__CHATTER__SLAVE_RAGDOLL__030__M__1
TT 20118 "Burada bir çocuk vardi... Sevimli." VO__SOPHIA__CH10__CHATTER__SLAVE_RAGDOLL__060__M__1
TT 20119 "O kadar çok kisiyi öldürdüler ki..." VO__SOPHIA__CH10__CHATTER__SO_MANY_DEAD_IDLE__020__M__1
TT 20120 "Beni yüzüstü birakma..." VO__SOPHIA__CH10__CHATTER__SOPHIA_SHOW_PRISM__010__M__1
TT 20121 "Pekâlâ. Yapiyorum." VO__SOPHIA__CH10__CHATTER__SOPHIA_SHOW_PRISM__040__M__1
TT 20122 "Evet, dogru..." VO__SOPHIA__CH10__CHATTER__SOPHIA_SHOW_PRISM__043__M__1
TT 20123 "Simdiye kadar iyi gidiyor!" VO__SOPHIA__CH10__CHATTER__SOPHIA_SHOW_PRISM__046__M__1
TT 20124 "Öff... Evet! En büyük hazinem! O atesin isigini yeterince toplayabileceginden emin degildim..." VO__SOPHIA__CH10__CHATTER__SOPHIA_SHOW_PRISM__060__M__1
