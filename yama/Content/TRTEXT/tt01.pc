TT 9020 "Yakala!" VO__BANDIT_N1__GENERIC__PATROL__ALERT_BOMB__001__M__3
TT 9021 "Al! Bu senin için!" VO__BANDIT_N1__GENERIC__PATROL__ALERT_BOMB__001__M__4
TT 9022 "Bu senin için!" VO__BANDIT_N1__GENERIC__PATROL__ALERT_BOMB__001__M__5
TT 9023 "Al bakalim!" VO__BANDIT_N1__GENERIC__PATROL__ALERT_BOMB__001__M__6
TT 9024 "Olamaz! Öldürüldü!" VO__BANDIT_N1__GENERIC__PATROL__ALERT_DYING__001__M__1
TT 9025 "Adam vuruldu!" VO__BANDIT_N1__GENERIC__PATROL__ALERT_DYING__001__M__2
TT 9026 "Siktir! Öldü!" VO__BANDIT_N1__GENERIC__PATROL__ALERT_DYING__001__M__3
