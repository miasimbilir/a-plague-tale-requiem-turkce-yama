TT 10667 "Her yeri arayin! Biri bela ariyor!" VO__BANDIT_S3__GENERIC__PATROL__AGAIN_SEARCH__001__M__1
TT 10668 "Biri bizimle oynuyor, bölgeyi tarayin!" VO__BANDIT_S3__GENERIC__PATROL__AGAIN_SEARCH__001__M__2
TT 10669 "Her yeri arayin! Iki kez yeterdi..." VO__BANDIT_S3__GENERIC__PATROL__AGAIN_SEARCH__001__M__3
