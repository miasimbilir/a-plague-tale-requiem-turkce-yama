TT 6665 "Hayir..." VO__AMICIA__CH11__RTC__555_COLLAPSE__030__M__1
TT 6666 "Hadi! Gel." VO__AMICIA__CH11__RTC__560_REMAINS_OF_A_CARRIER__005__M__1
