TT 6916 "ONU ALAMAYACAKSINIZ! DUYDUNUZ MU?! BITTI ARTIK!" VO__AMICIA__CH13__CHATTER__CHASE_TENSION__020__M__1
TT 6917 "Bilmek istemiyorum." VO__AMICIA__CH13__CHATTER__CLOSE_TO_CLIFF__020__M__1
TT 6918 "Evet..." VO__AMICIA__CH13__CHATTER__COMING_BACK__020__M__1
TT 6919 "Dikkat! Ben... kapiyi açiyorum..." VO__AMICIA__CH13__CHATTER__CROSSBOW_PULL__010__M__1
