TT 13905 "Evet!" VO__LUCAS__CH02__CHATTER__BASE_FALL_LUCASFALLS__070__M__1
TT 13906 "Tabii ki benim basima gelecekti..." VO__LUCAS__CH02__CHATTER__BASE_FALL_LUCASFALLS__080__M__1
TT 13907 "Gerçekten mi? Bir kiris mi?" VO__LUCAS__CH02__CHATTER__BASE_FALL_START__010__M__1
TT 13908 "Evet... Ben... Nefes almam lazim..." VO__LUCAS__CH02__CHATTER__BASE_INTRO_RATS__010__M__1
