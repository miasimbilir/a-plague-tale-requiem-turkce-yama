TT 13314 "Yapamam." VO__HUGO__CH16__CHATTER__RED_CITY_MARKET__030__M__1
TT 13315 "Simdiden unuttun mu?!" VO__HUGO__CH16__CHATTER__RED_CITY_MARKET__037__M__1
TT 13316 "Ben artik Macula'YIM! Öyleyim!" VO__HUGO__CH16__CHATTER__RED_CITY_MARKET__050__M__1
TT 13317 "Olabilecegini biliyordun. Çok geç." VO__HUGO__CH16__CHATTER__RED_CITY_MARKET__070__M__1
