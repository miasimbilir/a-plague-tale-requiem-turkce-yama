TT 7045 "onom" VO__AMICIA__CH13__RTC__682_EPAULE_ONOM__080__M__1
TT 7046 "Baska yol yok, Lucas." VO__AMICIA__CH13__RTC__685_RATS_NEST__010__M__1
TT 7047 "O seyleri Tasiyici'nin mezarinda gördük..." VO__AMICIA__CH13__RTC__685_RATS_NEST__030__M__1
TT 7048 "Ne?" VO__AMICIA__CH13__RTC__685_RATS_NEST__045__M__1
TT 7049 "Hayir, hayir, burasi yuva degil... Hugo, bana bak!" VO__AMICIA__CH13__RTC__685_RATS_NEST__090__M__1
TT 7050 "Ben... Onu kurtarmaliydim. Ama bunu hâlâ bitirebiliriz..." VO__AMICIA__CH13__RTC__685_RATS_NEST__120__M__1
TT 7051 "Beni duyuyor musun Hugo? O alçak Kont'u bulup öldürebiliriz!" VO__AMICIA__CH13__RTC__685_RATS_NEST__130__M__1
TT 7052 "Tamam... Tamam!" VO__AMICIA__CH13__RTC__685_RATS_NEST__160__M__1
TT 7053 "onom" VO__AMICIA__CH13__RTC__685_RATS_NEST_ONOM__010__M__1
TT 7054 "onom" VO__AMICIA__CH13__RTC__685_RATS_NEST_ONOM__030__M__1
TT 7055 "onom" VO__AMICIA__CH13__RTC__685_RATS_NEST_ONOM__040__M__1
